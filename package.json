{
  "name": "laragen",
  "displayName": "Laravel Generator Stub",
  "description": "Comprehensive Laravel API scaffolding tool with advanced code generation",
  "version": "1.0.4",
  "publisher": "waad-mawlood",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/waadmawlood/laragen-vscode.git"
  },
  "categories": ["Other", "Snippets"],
  "keywords": ["laravel", "php", "stub", "generator", "api", "scaffold"],
  "icon": "media/icon.png",
"activationEvents": [
    "onCommand:laragen.generate",
    "onView:laravelStubGenerator.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "laragen.generate",
        "title": "Generate Laravel Stubs",
        "category": "Laravel"
      },
      {
        "command": "laragen.batchGenerate",
        "title": "Batch Generate Laravel Stubs",
        "category": "Laravel"
      },
      {
        "command": "laragen.generateFromSchema",
        "title": "Generate Model from Migration Schema",
        "category": "Laravel"
      },
      {
        "command": "laragen.generateApiDocs",
        "title": "Generate OpenAPI Documentation",
        "category": "Laravel"
      },
      {
        "command": "laragen.rollback",
        "title": "Rollback Last Generation",
        "category": "Laravel"
      },
      {
        "command": "laragen.exportPreset",
        "title": "Export Configuration Preset",
        "category": "Laravel"
      },
      {
        "command": "laragen.importPreset",
        "title": "Import Configuration Preset",
        "category": "Laravel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "laragen",
          "title": "Laravel Stub Generator",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "laragen": [
        {
          "type": "webview",
          "id": "laravelStubGenerator.sidebar",
          "name": "Generator"
        }
      ]
    },
    "configuration": {
      "title": "Laravel Stub Generator",
      "properties": {
        "laravelStubGenerator.autoOpenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open generated files in editor"
        },
        "laravelStubGenerator.defaultMergeStrategy": {
          "type": "string",
          "enum": ["backup", "skip", "replace", "append"],
          "default": "backup",
          "description": "Default merge strategy when files already exist"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}
